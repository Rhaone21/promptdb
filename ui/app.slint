component BackupRow inherits Rectangle {
    in property <BackupItem> backup;
    callback restore-clicked();

    height: 44px;
    border-radius: Theme.radius-small;
    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.outline;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 10px;
        spacing: 8px;
        Text {
            text: backup.label;
            color: Theme.text;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        GhostButton { label: "Restore"; clicked-btn => { restore-clicked(); } }
    }
}

component BackupModal inherits ModalScrim {
    in property <[BackupItem]> backups;
    callback close-req();
    callback restore-req(int);

    card := Rectangle {
        width: min(420px, parent.width - 60px);
        height: min(420px, parent.height - 40px);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.surface-elevated;
        border-radius: Theme.radius;
        border-width: 1px;
        border-color: Theme.outline;

        TouchArea { clicked => { } }

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                Text {
                    text: "Restore Backup";
                    color: Theme.text;
                    font-size: 17px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }
                IconButton { icon-name: "close"; icon-size: 18px; clicked-btn => { close-req(); } }
            }

            if backups.length == 0 : Text {
                text: "Belum ada backup otomatis tersedia.";
                color: Theme.muted;
                font-size: 13px;
            }

            Flickable {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 6px;
                    for b in backups : BackupRow {
                        backup: b;
                        restore-clicked => { restore-req(b.slot); }
                    }
                }
            }
        }
    }
}

// ---- Toast ----

component Toast inherits Rectangle {
    // Root fills the window (default for an unconstrained child); the
    // visible bar is an inner child so it can reference `parent` (the root
    // itself is not allowed to reference its own future parent).
    in property <string> message;
    in property <string> kind: "success";

    bar := Rectangle {
        y: parent.height - self.height - 24px;
        x: (parent.width - self.width) / 2;
        width: txt.preferred-width + 32px;
        height: 42px;
        border-radius: Theme.radius-small;
        background: kind == "warning" ? Theme.danger : Theme.primary;

        txt := Text {
            text: message;
            color: #ffffff;
            font-size: 13px;
            font-weight: 600;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
    }
}

// ---- App window ----

export component AppWindow inherits Window {
    title: "PromptDB";
    preferred-width: 1200px;
    preferred-height: 800px;
    background: Theme.background;

    in property <[PromptItem]> prompts;
    in property <[FolderItem]> folders;
    in property <[FolderItem]> folder-options;
    in property <[TagItem]> tag-filter-items;
    in property <[TagItem]> tag-manage-items;
    in property <[TagItem]> edit-tag-items;
    in property <[BackupItem]> backups;
    in property <string> selected-folder-id: "";
    in property <string> tag-filter-mode: "AND";
    in property <int> selected-tag-count: 0;
    in property <bool> sidebar-collapsed: false;
    in property <bool> update-available: false;
    in property <string> update-version;
    in property <string> update-url;
    in property <string> toast-message: "";
    in property <string> toast-kind: "success";

    // Prompt modal state
    in property <bool> show-prompt-modal: false;
    in property <bool> prompt-is-edit: false;
    in property <string> prompt-created-label;
    in property <string> editing-id: "";
    in property <string> edit-folder-id: "";
    in property <string> edit-image-label: "";
    in property <bool> edit-has-image: false;
    in property <image> edit-image-preview;
    in-out property <string> edit-title: "";
    in-out property <string> edit-content: "";

    // Folder modal state
    in property <bool> show-folder-modal: false;
    in property <bool> folder-is-edit: false;
    in property <string> folder-error: "";
    in-out property <string> edit-folder-name: "";
    in-out property <string> edit-folder-icon: "";

    // Tag modal state
    in property <bool> show-tag-modal: false;
    in property <bool> tag-is-edit: false;
    in property <string> tag-error: "";
    in-out property <string> edit-tag-name: "";
    in property <color> edit-tag-color: #1F8EF1;

    // Backup modal state
    in property <bool> show-backup-modal: false;

    callback search(string);
    callback select-folder(string);
    callback copy(string);
    callback toggle-pin(string);
    callback cycle-theme();
    callback open-update();
    callback minimize-window();
    callback maximize-window();
    callback close-window();
    callback toggle-sidebar();

    callback open-add-prompt();
    callback open-edit-prompt(string);
    callback close-prompt-modal();
    callback save-prompt(string, string);
    callback delete-prompt();
    callback duplicate-prompt(string);
    callback select-edit-folder(string);
    callback toggle-edit-tag(string);
    callback attach-image();
    callback clear-image();

    callback open-add-folder();
    callback open-edit-folder(string);
    callback close-folder-modal();
    callback save-folder(string, string);
    callback delete-folder();
    callback request-delete-folder(string);

    callback open-tag-modal();
    callback close-tag-modal();
    callback save-tag(string);
    callback reset-tag-form();
    callback pick-tag-color(color);
    callback edit-tag(string);
    callback delete-tag(string);
    callback toggle-tag-filter(string);
    callback toggle-tag-filter-mode();
    callback clear-tag-filter();

    callback do-export();
    callback do-import();
    callback open-backups();
    callback close-backups();
    callback restore-backup(int);

    Rectangle {
        background: Theme.background;

        VerticalLayout {
            Header {
                update-available: root.update-available;
                update-version: root.update-version;
                theme-label: Theme.mode == "dark" ? "Dark" : Theme.mode == "oled" ? "OLED" : "Light";
                sidebar-collapsed: root.sidebar-collapsed;
                cycle-theme-req => { root.cycle-theme(); }
                open-update-req => { root.open-update(); }
                minimize-req => { root.minimize-window(); }
                maximize-req => { root.maximize-window(); }
                close-req => { root.close-window(); }
                toggle-sidebar-req => { root.toggle-sidebar(); }
            }

            Toolbar {
                search-changed(t) => { root.search(t); }
                add-prompt-req => { root.open-add-prompt(); }
                manage-tags-req => { root.open-tag-modal(); }
                import-req => { root.do-import(); }
                export-req => { root.do-export(); }
                backups-req => { root.open-backups(); }
            }

            HorizontalLayout {
                vertical-stretch: 1;

                Sidebar {
                    folders: root.folders;
                    selected-folder-id: root.selected-folder-id;
                    collapsed: root.sidebar-collapsed;
                    folder-selected(id) => { root.select-folder(id); }
                    edit-folder(id) => { root.open-edit-folder(id); }
                    delete-folder(id) => { root.request-delete-folder(id); }
                    add-folder => { root.open-add-folder(); }
                }

                MainArea {
                    prompts: root.prompts;
                    tag-filter-items: root.tag-filter-items;
                    tag-filter-mode: root.tag-filter-mode;
                    selected-tag-count: root.selected-tag-count;
                    search-changed(t) => { root.search(t); }
                    copy-requested(c) => { root.copy(c); }
                    pin-requested(id) => { root.toggle-pin(id); }
                    edit-requested(id) => { root.open-edit-prompt(id); }
                    duplicate-requested(id) => { root.duplicate-prompt(id); }
                    toggle-tag-filter(id) => { root.toggle-tag-filter(id); }
                    toggle-tag-mode => { root.toggle-tag-filter-mode(); }
                    clear-tag-filter => { root.clear-tag-filter(); }
                }
            }
        }

        if show-prompt-modal : PromptModal {
            is-edit: root.prompt-is-edit;
            created-label: root.prompt-created-label;
            title-text: root.edit-title;
            content-text: root.edit-content;
            folder-id: root.edit-folder-id;
            folder-options: root.folder-options;
            edit-tags: root.edit-tag-items;
            image-label: root.edit-image-label;
            has-image: root.edit-has-image;
            image-preview: root.edit-image-preview;
            close-req => { root.close-prompt-modal(); }
            save-req(t, c) => { root.edit-title = t; root.edit-content = c; root.save-prompt(t, c); }
            select-folder-req(id) => { root.select-edit-folder(id); }
            toggle-tag-req(id) => { root.toggle-edit-tag(id); }
            delete-req => { root.delete-prompt(); }
            duplicate-req => { root.duplicate-prompt(root.editing-id); }
            attach-image-req => { root.attach-image(); }
            clear-image-req => { root.clear-image(); }
        }

        if show-folder-modal : FolderModal {
            is-edit: root.folder-is-edit;
            error-text: root.folder-error;
            name-text: root.edit-folder-name;
            icon-text: root.edit-folder-icon;
            close-req => { root.close-folder-modal(); }
            save-req(n, i) => { root.edit-folder-name = n; root.edit-folder-icon = i; root.save-folder(n, i); }
            delete-req => { root.delete-folder(); }
        }

        if show-tag-modal : TagModal {
            is-edit: root.tag-is-edit;
            error-text: root.tag-error;
            name-text: root.edit-tag-name;
            color-value: root.edit-tag-color;
            tag-list: root.tag-manage-items;
            close-req => { root.close-tag-modal(); }
            save-req(n) => { root.edit-tag-name = n; root.save-tag(n); }
            reset-req => { root.reset-tag-form(); }
            pick-color(c) => { root.pick-tag-color(c); }
            edit-tag-req(id) => { root.edit-tag(id); }
            delete-tag-req(id) => { root.delete-tag(id); }
        }

        if show-backup-modal : BackupModal {
            backups: root.backups;
            close-req => { root.close-backups(); }
            restore-req(slot) => { root.restore-backup(slot); }
        }

        if toast-message != "" : Toast {
            message: root.toast-message;
            kind: root.toast-kind;
        }
    }
}
