// PromptDB native UI (Slint). Single-file: theme global, data structs,
// small reusable parts, then the AppWindow that wires them together.
// Rust (src/main.rs) owns all data/filtering logic and only pushes
// pre-computed `[PromptItem]` / `[FolderItem]` / `[TagItem]` models into
// this file. Modals are plain overlay Rectangles gated by `show-*` bools
// (per project convention — more predictable across Slint versions than
// PopupWindow).

export global Theme {
    in property <string> mode: "dark"; // "dark" | "oled" | "light"

    out property <color> background: mode == "light" ? #F5F4FA : mode == "oled" ? #000000 : #0d0c14;
    out property <color> surface: mode == "light" ? #FFFFFF : mode == "oled" ? #080610 : #131220;
    out property <color> surface-elevated: mode == "light" ? #FAFAFE : mode == "oled" ? #0f0c1c : #1c1a2a;
    out property <color> text: mode == "light" ? #16122a : mode == "oled" ? #F5F2FF : #ede9f0;
    out property <color> text-secondary: mode == "light" ? #4B4869 : mode == "oled" ? #A89EC0 : #d4cce3;
    out property <color> muted: mode == "light" ? #5e5688 : mode == "oled" ? #5a5270 : #8a8298;
    out property <color> primary: mode == "light" ? #7C3AED : mode == "oled" ? #A78BFA : #8B5CF6;
    out property <color> primary-pressed: primary.darker(0.18);
    out property <color> accent: mode == "light" ? #DB2777 : mode == "oled" ? #F472B6 : #EC4899;
    out property <color> outline: mode == "light" ? rgba(17, 10, 50, 0.09) : mode == "oled" ? rgba(255, 255, 255, 0.07) : rgba(255, 255, 255, 0.08);
    out property <color> danger: #E74C3C;

    out property <length> radius: 10px;
    out property <length> radius-small: 8px;
    out property <length> space-xs: 8px;
    out property <length> space-sm: 16px;
    out property <length> space-md: 24px;
    out property <length> space-lg: 32px;
    out property <length> sidebar-width: 240px;
    out property <length> header-height: 64px;
}

export struct PromptItem {
    id: string,
    title: string,
    preview: string,
    content: string,
    folder-name: string,
    pinned: bool,
    tag-names: [string],
    tag-colors: [color],
    has-image: bool,
    image: image,
}

export struct FolderItem {
    id: string,
    name: string,
    icon: string,
    count: int,
}

export struct TagItem {
    id: string,
    name: string,
    color: color,
    count: int,
    selected: bool,
}

export struct BackupItem {
    slot: int,
    label: string,
}

// ---- Small reusable parts ----

// Renders an iconsax SVG (assets/icons/<name>.svg) tinted to `tint`.
// SVGs are monochrome black+alpha, so colorize preserves the bulk two-tone
// look in any theme color. @image-url needs literal paths, hence the chain.
component Icon inherits Image {
    in property <string> name;
    in property <color> tint: Theme.text-secondary;
    in property <length> size: 16px;
    width: size;
    height: size;
    image-fit: contain;
    colorize: tint;
    source:
        name == "search" ? @image-url("../assets/icons/search.svg") :
        name == "close" ? @image-url("../assets/icons/close.svg") :
        name == "add" ? @image-url("../assets/icons/add.svg") :
        name == "plus" ? @image-url("../assets/icons/plus.svg") :
        name == "trash" ? @image-url("../assets/icons/trash.svg") :
        name == "edit" ? @image-url("../assets/icons/edit.svg") :
        name == "copy" ? @image-url("../assets/icons/copy.svg") :
        name == "duplicate" ? @image-url("../assets/icons/duplicate.svg") :
        name == "tag" ? @image-url("../assets/icons/tag.svg") :
        name == "folder" ? @image-url("../assets/icons/folder.svg") :
        name == "moon" ? @image-url("../assets/icons/moon.svg") :
        name == "sun" ? @image-url("../assets/icons/sun.svg") :
        name == "setting" ? @image-url("../assets/icons/setting.svg") :
        name == "arrowDown" ? @image-url("../assets/icons/arrowDown.svg") :
        name == "restore" ? @image-url("../assets/icons/restore.svg") :
        name == "tickSquare" ? @image-url("../assets/icons/tickSquare.svg") :
        name == "menu" ? @image-url("../assets/icons/menu.svg") :
        name == "import" ? @image-url("../assets/icons/import.svg") :
        name == "export" ? @image-url("../assets/icons/export.svg") :
        name == "keyboard" ? @image-url("../assets/icons/keyboard.svg") :
        name == "bookmark" ? @image-url("../assets/icons/bookmark.svg") :
        name == "data" ? @image-url("../assets/icons/data.svg") :
        name == "oled" ? @image-url("../assets/icons/oled.svg") :
        name == "grid" ? @image-url("../assets/icons/grid.svg") :
        name == "list" ? @image-url("../assets/icons/list.svg") :
        name == "winMin" ? @image-url("../assets/icons/winMin.svg") :
        name == "winMax" ? @image-url("../assets/icons/winMax.svg") :
        name == "winRestore" ? @image-url("../assets/icons/winRestore.svg") :
        @image-url("../assets/icons/add.svg");
}

component TagChip inherits Rectangle {
    in property <string> label;
    in property <color> tag-color;

    height: 22px;
    width: txt.preferred-width + 16px;
    border-radius: 6px;
    border-width: 1px;
    border-color: tag-color.with-alpha(0.4);
    background: tag-color.with-alpha(0.18);

    txt := Text {
        text: label;
        color: tag-color;
        font-size: 11px;
        x: 8px;
        y: (parent.height - self.height) / 2;
    }
}

component IconButton inherits Rectangle {
    in property <string> label;
    in property <string> icon-name: "";
    in property <color> fg: Theme.text-secondary;
    in property <length> btn-size: 30px;
    in property <length> icon-size: 16px;
    callback clicked-btn();

    width: btn-size;
    height: btn-size;
    border-radius: Theme.radius-small;
    background: area.pressed ? Theme.outline : (area.has-hover ? Theme.surface-elevated : transparent);

    if icon-name != "" : Icon {
        name: icon-name;
        tint: fg;
        size: icon-size;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }
    if icon-name == "" : Text {
        text: label;
        color: fg;
        font-size: 13px;
        width: 100%;
        height: 100%;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    area := TouchArea {
        clicked => { clicked-btn(); }
    }
}

component PrimaryButton inherits Rectangle {
    in property <string> label;
    in property <string> icon-name: "";
    in property <color> bg: Theme.primary;
    in property <color> fg: #ffffff;
    callback clicked-btn();

    height: 36px;
    width: row.preferred-width;
    border-radius: Theme.radius-small;
    background: area.pressed ? bg.darker(0.18) : (area.has-hover ? bg.darker(0.06) : bg);

    row := HorizontalLayout {
        alignment: center;
        padding-left: 14px;
        padding-right: 14px;
        spacing: 7px;
        if icon-name != "" : Icon { name: icon-name; tint: fg; size: 15px; }
        Text {
            text: label;
            color: fg;
            font-size: 13px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }

    area := TouchArea {
        clicked => { clicked-btn(); }
    }
}

component GhostButton inherits Rectangle {
    in property <string> label;
    in property <string> icon-name: "";
    in property <color> fg: Theme.text;
    callback clicked-btn();

    height: 36px;
    width: row.preferred-width;
    border-radius: Theme.radius-small;
    border-width: 1px;
    border-color: Theme.outline;
    background: area.pressed ? Theme.outline : (area.has-hover ? Theme.surface-elevated : transparent);

    row := HorizontalLayout {
        alignment: center;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 6px;
        if icon-name != "" : Icon { name: icon-name; tint: fg; size: 15px; }
        Text {
            text: label;
            color: fg;
            font-size: 13px;
            vertical-alignment: center;
        }
    }

    area := TouchArea {
        clicked => { clicked-btn(); }
    }
}

component LabeledInput inherits VerticalLayout {
    in property <string> label-text;
    in property <string> placeholder;
    in property <bool> multiline: false;
    in-out property <string> text-value <=> input.text;
    callback edited-text(string);

    spacing: 6px;

    Text {
        text: label-text;
        color: Theme.text-secondary;
        font-size: 12px;
        font-weight: 600;
    }

    Rectangle {
        height: multiline ? 180px : 38px;
        clip: true;
        border-radius: Theme.radius-small;
        background: Theme.surface;
        border-width: 1px;
        border-color: input.has-focus ? Theme.primary : Theme.outline;

        if input.text == "" : Text {
            text: placeholder;
            color: Theme.muted;
            x: 12px;
            y: 10px;
            font-size: 13px;
        }

        Flickable {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: parent.height - 2px;
            viewport-width: self.width;
            viewport-height: max(self.height, input.preferred-height + 20px);

            input := TextInput {
                x: 11px;
                y: 9px;
                width: parent.width - 22px;
                color: Theme.text;
                font-size: 13px;
                single-line: !multiline;
                wrap: multiline ? word-wrap : no-wrap;
                edited => { root.edited-text(self.text); }
            }
        }
    }
}

component ModalScrim inherits Rectangle {
    background: rgba(0, 0, 0, 0.55);
    TouchArea { clicked => { } } // swallow clicks so they don't fall through to the app behind
}

// ---- Sidebar ----

component SidebarItem inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <int> count;
    in property <bool> selected;
    in property <bool> show-actions: false;
    callback clicked-item();
    callback edit-clicked();
    callback delete-clicked();

    height: 40px;
    border-radius: Theme.radius-small;
    background: selected ? Theme.primary.with-alpha(0.16) : (area.has-hover ? Theme.surface-elevated : transparent);

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 8px;
        spacing: 8px;

        Text {
            text: icon;
            font-size: 15px;
            vertical-alignment: center;
        }
        Text {
            text: label;
            color: selected ? Theme.primary : Theme.text;
            font-size: 13px;
            font-weight: selected ? 600 : 400;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        Text {
            text: count;
            color: Theme.muted;
            font-size: 12px;
            vertical-alignment: center;
        }
        if show-actions && area.has-hover : HorizontalLayout {
            spacing: 2px;
            IconButton { icon-name: "edit"; icon-size: 14px; btn-size: 24px; clicked-btn => { edit-clicked(); } }
            IconButton { icon-name: "trash"; icon-size: 14px; btn-size: 24px; fg: Theme.danger; clicked-btn => { delete-clicked(); } }
        }
    }

    area := TouchArea {
        clicked => { clicked-item(); }
    }
}

component Sidebar inherits Rectangle {
    in property <[FolderItem]> folders;
    in property <string> selected-folder-id;
    in property <bool> collapsed: false;
    callback folder-selected(string);
    callback edit-folder(string);
    callback delete-folder(string);
    callback add-folder();

    width: collapsed ? 0px : Theme.sidebar-width;
    clip: true;
    background: Theme.surface;
    border-width: collapsed ? 0px : 1px;
    border-color: Theme.outline;

    VerticalLayout {
        // Brand header
        Rectangle {
            height: 60px;
            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 10px;
                Image {
                    source: @image-url("../icons/icon-brand.png");
                    width: 32px;
                    height: 32px;
                    image-fit: contain;
                }
                VerticalLayout {
                    alignment: center;
                    Text { text: "PromptDB"; color: Theme.text; font-size: 15px; font-weight: 700; }
                    Text { text: "Penyimpanan Lokal"; color: Theme.muted; font-size: 11px; }
                }
            }
        }
        Rectangle { height: 1px; background: Theme.outline; }

        // Section label
        Rectangle {
            height: 30px;
            Text {
                text: "FOLDER";
                color: Theme.muted;
                font-size: 11px;
                font-weight: 600;
                letter-spacing: 0.5px;
                x: 14px;
                y: (parent.height - self.height) / 2;
            }
        }

        Flickable {
            vertical-stretch: 1;
            VerticalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-bottom: 12px;
                spacing: 4px;
                alignment: start;

                for f[i] in folders : SidebarItem {
                    label: f.name;
                    icon: f.icon;
                    count: f.count;
                    selected: f.id == selected-folder-id;
                    show-actions: f.id != "";
                    clicked-item => { folder-selected(f.id); }
                    edit-clicked => { edit-folder(f.id); }
                    delete-clicked => { delete-folder(f.id); }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: Theme.outline;
        }

        Rectangle {
            height: 46px;
            add-area := TouchArea {
                clicked => { add-folder(); }
            }
            HorizontalLayout {
                padding: 12px;
                spacing: 8px;
                alignment: start;
                Icon { name: "add"; tint: add-area.has-hover ? Theme.primary : Theme.text-secondary; size: 16px; }
                Text {
                    text: "Folder Baru";
                    color: add-area.has-hover ? Theme.primary : Theme.text-secondary;
                    font-size: 13px;
                    vertical-alignment: center;
                }
            }
        }
    }
}

// ---- Title bar ----

component TitleBarButton inherits Rectangle {
    in property <string> icon-name;
    in property <bool> is-close: false;
    callback clicked-btn();

    width: 40px;
    height: 30px;
    border-radius: 6px;
    background: area.pressed
        ? (is-close ? Theme.danger : Theme.outline)
        : (area.has-hover ? (is-close ? Theme.danger.with-alpha(0.85) : Theme.surface) : transparent);

    Icon {
        name: icon-name;
        tint: (is-close && area.has-hover) ? #ffffff : Theme.text-secondary;
        size: 13px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
    }

    area := TouchArea {
        clicked => { clicked-btn(); }
    }
}

component Header inherits Rectangle {
    in property <bool> update-available;
    in property <string> update-version;
    in property <string> theme-label;
    in property <bool> sidebar-collapsed;
    callback cycle-theme-req();
    callback open-update-req();
    callback minimize-req();
    callback maximize-req();
    callback close-req();
    callback toggle-sidebar-req();

    height: Theme.header-height;
    background: Theme.surface-elevated;
    border-width: 1px;
    border-color: Theme.outline;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 10px;
        spacing: 10px;

        IconButton {
            icon-name: "menu";
            clicked-btn => { toggle-sidebar-req(); }
        }

        // Brand: logo + wordmark
        Image {
            source: @image-url("../icons/icon-brand.png");
            width: 26px;
            height: 26px;
            image-fit: contain;
        }
        Text {
            text: "PromptDB";
            color: Theme.text;
            font-size: 17px;
            font-weight: 700;
            vertical-alignment: center;
        }

        Rectangle { horizontal-stretch: 1; }

        if update-available : Rectangle {
            width: update-row.preferred-width + 24px;
            height: 32px;
            border-radius: Theme.radius-small;
            background: update-area.pressed ? Theme.accent.darker(0.15) : Theme.accent;

            update-row := HorizontalLayout {
                alignment: center;
                spacing: 6px;
                Icon { name: "restore"; tint: #ffffff; size: 14px; }
                Text {
                    text: "Update v" + update-version;
                    color: #ffffff;
                    font-size: 12px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }

            update-area := TouchArea {
                clicked => { open-update-req(); }
            }
        }

        // Theme toggle (icon reflects current mode)
        IconButton {
            icon-name: Theme.mode == "light" ? "sun" : Theme.mode == "oled" ? "oled" : "moon";
            fg: Theme.text;
            clicked-btn => { cycle-theme-req(); }
        }

        HorizontalLayout {
            spacing: 4px;
            TitleBarButton { icon-name: "winMin"; clicked-btn => { minimize-req(); } }
            TitleBarButton { icon-name: "winMax"; clicked-btn => { maximize-req(); } }
            TitleBarButton { icon-name: "close"; is-close: true; clicked-btn => { close-req(); } }
        }
    }
}

// ---- Toolbar: search + prompt/tag/data actions ----

component SearchBox inherits Rectangle {
    callback edited(string);

    height: 38px;
    horizontal-stretch: 1;
    border-radius: Theme.radius-small;
    background: Theme.surface;
    border-width: 1px;
    border-color: input.has-focus ? Theme.primary : Theme.outline;

    Icon {
        name: "search";
        tint: Theme.muted;
        size: 16px;
        x: 12px;
        y: (parent.height - self.height) / 2;
    }

    if input.text == "" : Text {
        text: "Cari judul atau isi prompt...";
        color: Theme.muted;
        x: 38px;
        y: (parent.height - self.height) / 2;
        font-size: 13px;
    }

    input := TextInput {
        x: 38px;
        width: parent.width - 50px;
        y: (parent.height - self.height) / 2;
        color: Theme.text;
        font-size: 13px;
        single-line: true;
        edited => { root.edited(self.text); }
    }
}

component Toolbar inherits Rectangle {
    callback search-changed(string);
    callback add-prompt-req();
    callback manage-tags-req();
    callback import-req();
    callback export-req();
    callback backups-req();

    height: 56px;
    background: Theme.background;

    HorizontalLayout {
        padding: 10px;
        spacing: 8px;

        SearchBox { edited(t) => { search-changed(t); } }
        PrimaryButton { icon-name: "add"; label: "Tambah Prompt"; clicked-btn => { add-prompt-req(); } }
        GhostButton { icon-name: "tag"; label: "Kelola Tag"; clicked-btn => { manage-tags-req(); } }
        GhostButton { icon-name: "import"; label: "Import"; clicked-btn => { import-req(); } }
        GhostButton { icon-name: "export"; label: "Export"; clicked-btn => { export-req(); } }
        GhostButton { icon-name: "restore"; label: "Backup"; clicked-btn => { backups-req(); } }
    }
}

// ---- Tag filter bar ----

component TagFilterChip inherits Rectangle {
    in property <string> label;
    in property <color> dot-color;
    in property <bool> show-dot: true;
    in property <bool> selected;
    callback clicked-chip();

    height: 26px;
    width: layout.preferred-width + 16px;
    border-radius: 13px;
    border-width: 1px;
    border-color: selected ? Theme.primary : Theme.outline;
    background: selected ? Theme.primary.with-alpha(0.18) : (area.has-hover ? Theme.surface-elevated : Theme.surface);

    layout := HorizontalLayout {
        x: 8px;
        y: (parent.height - self.height) / 2;
        spacing: 5px;
        alignment: center;

        if show-dot : Rectangle {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: dot-color;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: label;
            color: selected ? Theme.primary : Theme.text;
            font-size: 12px;
            font-weight: selected ? 600 : 400;
        }
    }

    area := TouchArea {
        clicked => { clicked-chip(); }
    }
}

component TagFilterBar inherits Rectangle {
    in property <[TagItem]> tags;
    in property <string> filter-mode: "AND";
    in property <int> selected-count: 0;
    callback toggle-tag(string);
    callback toggle-mode();
    callback clear-filter();

    height: tags.length > 0 || selected-count > 0 ? 42px : 0px;
    clip: true;

    Flickable {
        HorizontalLayout {
            padding: 6px;
            spacing: 6px;

            if selected-count > 0 : TagFilterChip {
                label: "Reset Filter (" + selected-count + ")";
                show-dot: false;
                selected: true;
                clicked-chip => { clear-filter(); }
            }

            for t in tags : TagFilterChip {
                label: t.name;
                dot-color: t.color;
                selected: t.selected;
                clicked-chip => { toggle-tag(t.id); }
            }

            if selected-count > 1 : TagFilterChip {
                label: filter-mode == "AND" ? "Mode: AND" : "Mode: OR";
                show-dot: false;
                selected: false;
                clicked-chip => { toggle-mode(); }
            }
        }
    }
}

// ---- Prompt grid ----

component PromptCard inherits Rectangle {
    in property <PromptItem> item;
    callback copy-requested(string);
    callback pin-requested(string);
    callback edit-requested(string);
    callback duplicate-requested(string);

    clip: true;
    background: Theme.surface;
    border-radius: Theme.radius;
    border-width: 1px;
    border-color: card-area.has-hover ? Theme.primary.with-alpha(0.45) : Theme.outline;

    card-area := TouchArea {
        clicked => { edit-requested(item.id); }
    }

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        // Title + pin marker
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: item.title;
                color: Theme.text;
                font-size: 15px;
                font-weight: 600;
                horizontal-stretch: 1;
                overflow: elide;
                vertical-alignment: center;
            }
            if item.pinned : Icon { name: "bookmark"; tint: Theme.primary; size: 15px; }
        }

        if item.has-image : Image {
            source: item.image;
            height: 72px;
            width: 100%;
            image-fit: cover;
        }

        // Preview fills the slack so the footer pins to the bottom (uniform grid).
        Text {
            text: item.preview;
            color: Theme.text-secondary;
            font-size: 12.5px;
            wrap: word-wrap;
            overflow: elide;
            vertical-stretch: 1;
        }

        // Folder line
        HorizontalLayout {
            spacing: 5px;
            Icon { name: "folder"; tint: Theme.muted; size: 13px; }
            Text {
                text: item.folder-name;
                color: Theme.muted;
                font-size: 11.5px;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
        }

        // Tags
        Rectangle {
            height: 22px;
            clip: true;
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                for name[i] in item.tag-names : TagChip {
                    label: name;
                    tag-color: item.tag-colors[i];
                }
            }
        }

        // Actions
        HorizontalLayout {
            alignment: end;
            spacing: 6px;

            IconButton {
                icon-name: "bookmark";
                icon-size: 15px;
                fg: item.pinned ? Theme.primary : Theme.muted;
                clicked-btn => { pin-requested(item.id); }
            }
            IconButton {
                icon-name: "duplicate";
                icon-size: 15px;
                clicked-btn => { duplicate-requested(item.id); }
            }
            copy-btn := Rectangle {
                width: 76px;
                height: 30px;
                border-radius: Theme.radius-small;
                background: copy-area.pressed ? Theme.primary-pressed : (copy-area.has-hover ? Theme.primary.darker(0.05) : Theme.primary);

                HorizontalLayout {
                    alignment: center;
                    spacing: 5px;
                    Icon { name: "copy"; tint: #ffffff; size: 13px; }
                    Text {
                        text: "Copy";
                        color: #ffffff;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }

                copy-area := TouchArea {
                    clicked => { copy-requested(item.content); }
                }
            }
        }
    }
}

component MainArea inherits Rectangle {
    in property <[PromptItem]> prompts;
    in property <[TagItem]> tag-filter-items;
    in property <string> tag-filter-mode;
    in property <int> selected-tag-count;
    callback search-changed(string);
    callback copy-requested(string);
    callback pin-requested(string);
    callback edit-requested(string);
    callback duplicate-requested(string);
    callback toggle-tag-filter(string);
    callback toggle-tag-mode();
    callback clear-tag-filter();

    horizontal-stretch: 1;
    background: Theme.background;

    VerticalLayout {
        TagFilterBar {
            tags: tag-filter-items;
            filter-mode: tag-filter-mode;
            selected-count: selected-tag-count;
            toggle-tag(id) => { toggle-tag-filter(id); }
            toggle-mode => { toggle-tag-mode(); }
            clear-filter => { clear-tag-filter(); }
        }

        Flickable {
            viewport-width: self.width;
            viewport-height: grid.height;

            grid := Rectangle {
                width: parent.width;
                property <length> pad: 20px;
                property <length> gap: 16px;
                property <length> mincard: 300px;
                // Reflow: as many columns of >=mincard as the width allows.
                property <int> cols: Math.max(1, Math.floor((self.width - 2 * pad + gap) / (mincard + gap)));
                property <length> card-w: (self.width - 2 * pad - (cols - 1) * gap) / cols;
                property <length> card-h: 210px;
                property <int> rows: Math.ceil(prompts.length / cols);
                height: prompts.length > 0 ? (rows * (card-h + gap) - gap + 2 * pad) : 260px;

                for it[idx] in prompts : PromptCard {
                    item: it;
                    width: grid.card-w;
                    height: grid.card-h;
                    x: grid.pad + Math.mod(idx, grid.cols) * (grid.card-w + grid.gap);
                    y: grid.pad + Math.floor(idx / grid.cols) * (grid.card-h + grid.gap);
                    copy-requested(c) => { copy-requested(c); }
                    pin-requested(id) => { pin-requested(id); }
                    edit-requested(id) => { edit-requested(id); }
                    duplicate-requested(id) => { duplicate-requested(id); }
                }

                if prompts.length == 0 : Text {
                    text: "Tidak ada prompt. Klik \"+ Tambah Prompt\" untuk membuat yang baru.";
                    color: Theme.muted;
                    font-size: 14px;
                    x: (parent.width - self.width) / 2;
                    y: 48px;
                }
            }
        }
    }
}

// ---- Prompt modal ----

component PromptModal inherits ModalScrim {
    in property <bool> is-edit;
    in property <string> created-label;
    in-out property <string> title-text;
    in-out property <string> content-text;
    in property <string> folder-id;
    in property <[FolderItem]> folder-options;
    in property <[TagItem]> edit-tags;
    in property <string> image-label;
    in property <bool> has-image;
    in property <image> image-preview;

    callback close-req();
    callback save-req(string, string);
    callback select-folder-req(string);
    callback toggle-tag-req(string);
    callback delete-req();
    callback duplicate-req();
    callback attach-image-req();
    callback clear-image-req();

    property <bool> confirm-delete: false;
    confirm-timer := Timer {
        interval: 3s;
        running: confirm-delete;
        triggered => { confirm-delete = false; }
    }

    card := Rectangle {
        width: min(620px, parent.width - 60px);
        height: min(680px, parent.height - 40px);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.surface-elevated;
        border-radius: Theme.radius;
        border-width: 1px;
        border-color: Theme.outline;

        // Absorb clicks so the scrim behind doesn't also receive them.
        TouchArea { clicked => { } }

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                Text {
                    text: is-edit ? "Edit Prompt" : "Tambah Prompt";
                    color: Theme.text;
                    font-size: 18px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }
                IconButton { icon-name: "close"; icon-size: 18px; clicked-btn => { close-req(); } }
            }

            if is-edit : Text {
                text: created-label;
                color: Theme.muted;
                font-size: 11px;
            }

            Flickable {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 14px;

                    LabeledInput {
                        label-text: "Judul";
                        placeholder: "Judul prompt";
                        text-value: root.title-text;
                        edited-text(v) => { root.title-text = v; }
                    }

                    LabeledInput {
                        label-text: "Isi Prompt";
                        placeholder: "Tulis isi prompt di sini...";
                        multiline: true;
                        text-value: root.content-text;
                        edited-text(v) => { root.content-text = v; }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        Text { text: "Folder"; color: Theme.text-secondary; font-size: 12px; font-weight: 600; }
                        Flickable {
                            height: 34px;
                            HorizontalLayout {
                                spacing: 6px;
                                for f in folder-options : TagFilterChip {
                                    label: f.icon + " " + f.name;
                                    show-dot: false;
                                    selected: f.id == root.folder-id;
                                    clicked-chip => { select-folder-req(f.id); }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        Text { text: "Tag"; color: Theme.text-secondary; font-size: 12px; font-weight: 600; }
                        Flickable {
                            height: edit-tags.length > 0 ? 34px : 20px;
                            HorizontalLayout {
                                spacing: 6px;
                                for t in edit-tags : TagFilterChip {
                                    label: t.name;
                                    dot-color: t.color;
                                    selected: t.selected;
                                    clicked-chip => { toggle-tag-req(t.id); }
                                }
                                if edit-tags.length == 0 : Text {
                                    text: "Belum ada tag. Buat lewat \"Kelola Tag\".";
                                    color: Theme.muted;
                                    font-size: 12px;
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        Text { text: "Gambar (opsional)"; color: Theme.text-secondary; font-size: 12px; font-weight: 600; }
                        HorizontalLayout {
                            spacing: 8px;
                            if has-image : Image {
                                source: image-preview;
                                width: 46px;
                                height: 46px;
                                image-fit: cover;
                            }
                            Text {
                                text: has-image ? image-label : "Tidak ada gambar";
                                color: Theme.muted;
                                font-size: 12px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            GhostButton { label: "Pilih..."; clicked-btn => { attach-image-req(); } }
                            if has-image : GhostButton { label: "Hapus"; clicked-btn => { clear-image-req(); } }
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px;
                if is-edit : GhostButton {
                    label: confirm-delete ? "Yakin Hapus?" : "Hapus";
                    fg: Theme.danger;
                    clicked-btn => {
                        if confirm-delete {
                            confirm-delete = false;
                            delete-req();
                        } else {
                            confirm-delete = true;
                        }
                    }
                }
                if is-edit : GhostButton { label: "Duplikat"; clicked-btn => { duplicate-req(); } }
                Rectangle { horizontal-stretch: 1; }
                GhostButton { label: "Batal"; clicked-btn => { close-req(); } }
                PrimaryButton { label: "Simpan"; clicked-btn => { save-req(root.title-text, root.content-text); } }
            }
        }
    }
}

// ---- Folder modal ----

component FolderModal inherits ModalScrim {
    in property <bool> is-edit;
    in property <string> error-text;
    in-out property <string> name-text;
    in-out property <string> icon-text;

    callback close-req();
    callback save-req(string, string);
    callback delete-req();

    card := Rectangle {
        width: min(420px, parent.width - 60px);
        height: content.preferred-height + 40px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.surface-elevated;
        border-radius: Theme.radius;
        border-width: 1px;
        border-color: Theme.outline;

        TouchArea { clicked => { } }

        content := VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                Text {
                    text: is-edit ? "Edit Folder" : "Tambah Folder";
                    color: Theme.text;
                    font-size: 17px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }
                IconButton { icon-name: "close"; icon-size: 18px; clicked-btn => { close-req(); } }
            }

            HorizontalLayout {
                spacing: 10px;
                VerticalLayout {
                    width: 70px;
                    spacing: 6px;
                    Text { text: "Ikon"; color: Theme.text-secondary; font-size: 12px; font-weight: 600; }
                    Rectangle {
                        height: 38px;
                        border-radius: Theme.radius-small;
                        background: Theme.surface;
                        border-width: 1px;
                        border-color: icon-input.has-focus ? Theme.primary : Theme.outline;
                        icon-input := TextInput {
                            x: 10px;
                            width: parent.width - 20px;
                            y: (parent.height - self.height) / 2;
                            color: Theme.text;
                            font-size: 16px;
                            single-line: true;
                            text: root.icon-text;
                            edited => { root.icon-text = self.text; }
                        }
                    }
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 6px;
                    Text { text: "Nama Folder"; color: Theme.text-secondary; font-size: 12px; font-weight: 600; }
                    Rectangle {
                        height: 38px;
                        border-radius: Theme.radius-small;
                        background: Theme.surface;
                        border-width: 1px;
                        border-color: name-input.has-focus ? Theme.primary : Theme.outline;
                        name-input := TextInput {
                            x: 10px;
                            width: parent.width - 20px;
                            y: (parent.height - self.height) / 2;
                            color: Theme.text;
                            font-size: 13px;
                            single-line: true;
                            text: root.name-text;
                            edited => { root.name-text = self.text; }
                        }
                    }
                }
            }

            if error-text != "" : Text {
                text: error-text;
                color: Theme.danger;
                font-size: 12px;
                wrap: word-wrap;
            }

            HorizontalLayout {
                spacing: 8px;
                if is-edit : IconButton {
                    label: "Hapus";
                    fg: Theme.danger;
                    width: 60px;
                    clicked-btn => { delete-req(); }
                }
                Rectangle { horizontal-stretch: 1; }
                GhostButton { label: "Batal"; clicked-btn => { close-req(); } }
                PrimaryButton { label: "Simpan"; clicked-btn => { save-req(root.name-text, root.icon-text); } }
            }
        }
    }
}

// ---- Tag modal ----

component TagListRow inherits Rectangle {
    in property <TagItem> tag;
    callback edit-clicked();
    callback delete-clicked();

    height: 38px;
    border-radius: Theme.radius-small;
    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.outline;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 8px;
        spacing: 8px;

        Rectangle {
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background: tag.color;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: tag.name + " (" + tag.count + ")";
            color: Theme.text;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        IconButton { icon-name: "edit"; icon-size: 14px; btn-size: 24px; clicked-btn => { edit-clicked(); } }
        IconButton { icon-name: "trash"; icon-size: 14px; btn-size: 24px; fg: Theme.danger; clicked-btn => { delete-clicked(); } }
    }
}

component TagModal inherits ModalScrim {
    in property <bool> is-edit;
    in property <string> error-text;
    in-out property <string> name-text;
    in property <color> color-value;
    in property <[TagItem]> tag-list;

    callback close-req();
    callback save-req(string);
    callback reset-req();
    callback pick-color(color);
    callback edit-tag-req(string);
    callback delete-tag-req(string);

    property <[color]> palette: [#1F8EF1, #9B59B6, #2ECC71, #F39C12, #E67E22, #E74C3C, #16A085, #F1C40F];

    card := Rectangle {
        width: min(460px, parent.width - 60px);
        height: min(560px, parent.height - 40px);
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: Theme.surface-elevated;
        border-radius: Theme.radius;
        border-width: 1px;
        border-color: Theme.outline;

        TouchArea { clicked => { } }

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                Text {
                    text: "Kelola Tag";
                    color: Theme.text;
                    font-size: 17px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }
                IconButton { icon-name: "close"; icon-size: 18px; clicked-btn => { close-req(); } }
            }

            Rectangle {
                height: 38px;
                border-radius: Theme.radius-small;
                background: Theme.surface;
                border-width: 1px;
                border-color: name-input.has-focus ? Theme.primary : Theme.outline;
                name-input := TextInput {
                    x: 10px;
                    width: parent.width - 20px;
                    y: (parent.height - self.height) / 2;
                    color: Theme.text;
                    font-size: 13px;
                    single-line: true;
                    text: root.name-text;
                    edited => { root.name-text = self.text; }
                }
            }

            HorizontalLayout {
                spacing: 6px;
                for c in palette : Rectangle {
                    width: 24px;
                    height: 24px;
                    border-radius: 12px;
                    background: c;
                    border-width: c == color-value ? 2px : 0px;
                    border-color: Theme.text;
                    TouchArea { clicked => { pick-color(c); } }
                }
            }

            if error-text != "" : Text {
                text: error-text;
                color: Theme.danger;
                font-size: 12px;
            }

            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; }
                if is-edit : GhostButton { label: "Batal Edit"; clicked-btn => { reset-req(); } }
                PrimaryButton { label: is-edit ? "Update Tag" : "Tambah Tag"; clicked-btn => { save-req(root.name-text); } }
            }

            Rectangle { height: 1px; background: Theme.outline; }

            Flickable {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 6px;
                    for t in tag-list : TagListRow {
                        tag: t;
                        edit-clicked => { edit-tag-req(t.id); }
                        delete-clicked => { delete-tag-req(t.id); }
                    }
                }
            }
        }
    }
}

